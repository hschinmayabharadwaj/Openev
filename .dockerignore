# Documentation source files (*.md) but keep the docs/ folder which
# now contains user-facing pages (judge, lab, play, heist, walkthrough)
# served at runtime. We still ignore *.md at the repo root, but allow
# docs/walkthrough.md so /walkthrough.md serves the source.
*.md
!README.md
!docs/walkthrough.md

# CI/CD
.github
.gitlab-ci.yml

# Node (if any)
node_modules/
npm-debug.log

# Hackathon briefing slides + any other PDFs are not part of the env
*.pdf

# Multi-GB checkpoints. The runtime falls back to the heuristic/expert
# policy when no checkpoint is present, so we don't ship weights to the
# Space (judges can re-train via the Colab notebook).
artifacts/trl-neon-model/model.safetensors
notebooks/artifacts/trl-neon-model/model.safetensors
notebooks/artifacts/trl-neon-model/tokenizer.json
notebooks/artifacts/trl-neon-model/vocab.json
notebooks/artifacts/trl-neon-model/merges.txt
